# =============================================================================
# KALSHI AI TRADING BOT — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your keys before running.
# =============================================================================

# ─── Kalshi ───────────────────────────────────────────────────────────────────
# Get your API key at: https://trading.kalshi.com/settings/api
KALSHI_API_KEY=your_kalshi_api_key_here

# Private key — ONLY required for LIVE trading. Leave blank for sandbox/paper.
KALSHI_PRIVATE_KEY_PATH=

# ─── xAI / Grok ───────────────────────────────────────────────────────────────
# Get your API key at: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# ─── Anthropic / Claude ────────────────────────────────────────────────────────
# Adds a second AI layer for dual-model consensus (optional but recommended).
#   Lean Mode  → Claude Opus 4.6  (deep analysis, ~$0.01-0.02 per market)
#   Beast Mode → Claude Haiku 4.5 (fast signal gate, < $0.001 per signal)
# Get your API key at: https://console.anthropic.com/
# Leave blank to run in Grok-only mode.
ANTHROPIC_API_KEY=

# ─── Mode ─────────────────────────────────────────────────────────────────────
# KEEP FALSE until you are ready for real money.
LIVE_TRADING_ENABLED=false
PHASE_MODE_ENABLED=true

# ─── Optional free data API keys (lean bot enrichment) ────────────────────────
# The Odds API — https://the-odds-api.com (500 req/month free tier)
ODDS_API_KEY=

# FRED (Federal Reserve economic data) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Metaculus forecasting — https://www.metaculus.com/accounts/profile/#apikey
METACULUS_API_KEY=

# NewsAPI — https://newsapi.org/register (100 req/day free tier)
NEWSAPI_KEY=

# BLS (Bureau of Labor Statistics) — https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# Jolpica F1, Manifold, PredictIt, NWS — no key required, work out of the box.

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
